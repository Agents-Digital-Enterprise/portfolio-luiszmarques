---
---
<section class="min-h-[90vh] flex items-center px-4">
  <div class="max-w-5xl mx-auto w-full py-20">
    <div class="max-w-3xl">
      <!-- Pre-heading label -->
      <div class="inline-flex items-center gap-2 bg-accent-subtle border border-accent/30 rounded-full px-3 py-1 text-accent-light text-sm font-medium mb-8">
        <span class="w-2 h-2 rounded-full bg-accent-light animate-pulse"></span>
        Available for new opportunities
      </div>

      <!-- Name -->
      <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold tracking-tight leading-none mb-4">
        Luis
        <span class="block text-accent-light">Marques</span>
      </h1>

      <!-- Role -->
      <p class="text-xl sm:text-2xl text-text-secondary font-medium mb-6">
        Senior Full-Stack Engineer
      </p>

      <!-- Tagline -->
      <p class="text-lg text-text-secondary leading-relaxed mb-10 max-w-2xl">
        I design and ship full-stack systems end-to-end — from Cloudflare BFF architecture
        and federated GraphQL schemas to Vue frontends, AWS infrastructure, and production
        data migrations. I own the delivery, not just the ticket.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4">
        <a
          href="/projects"
          class="inline-flex items-center gap-2 bg-accent hover:bg-accent-hover text-white font-medium px-6 py-3 rounded-lg transition-colors focus-visible:outline-2 focus-visible:outline-accent-light focus-visible:outline-offset-2"
        >
          View Projects
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
        <a
          href="/contact"
          class="inline-flex items-center gap-2 border border-border hover:border-accent/50 text-text-primary hover:text-accent-light font-medium px-6 py-3 rounded-lg transition-colors focus-visible:outline-2 focus-visible:outline-accent-light focus-visible:outline-offset-2"
        >
          Get in touch
        </a>
        <a
          href="https://github.com/LuisZMarques"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-text-secondary hover:text-text-primary font-medium px-6 py-3 rounded-lg transition-colors focus-visible:outline-2 focus-visible:outline-accent-light focus-visible:outline-offset-2"
          aria-label="GitHub profile"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
          </svg>
          GitHub
        </a>
      </div>

      <!-- Tech stack strip -->
      <div class="mt-16 pt-8 border-t border-border">
        <p class="text-text-muted text-xs uppercase tracking-widest mb-4">Core stack</p>
        <div class="flex flex-wrap gap-2">
          {['Vue 3', 'TypeScript', 'Cloudflare Workers', 'GraphQL', 'AWS', 'Node.js'].map(tech => (
            <span class="text-xs text-text-secondary bg-bg-surface border border-border px-3 py-1 rounded-full">
              {tech}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
