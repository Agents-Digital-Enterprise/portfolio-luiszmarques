---
import MobileNav from '@/components/MobileNav.vue';
import { navLinks } from '@/data/nav';

interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;
---
<header class="sticky top-0 z-50 bg-bg/80 backdrop-blur-md border-b border-border">
  <div class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href="/" class="font-semibold text-text-primary hover:text-accent-light transition-colors text-lg tracking-tight focus-visible:outline-2 focus-visible:outline-accent-light focus-visible:outline-offset-2 rounded">
      Luis Marques
    </a>

    <!-- Desktop nav -->
    <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
      {navLinks.map(({ label, href }) => (
        <a
          href={href}
          class={`text-sm transition-colors focus-visible:outline-2 focus-visible:outline-accent-light focus-visible:outline-offset-2 rounded ${
            currentPath.startsWith(href)
              ? 'text-accent-light'
              : 'text-text-secondary hover:text-text-primary'
          }`}
          aria-current={currentPath.startsWith(href) ? 'page' : undefined}
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Mobile nav (Vue island) -->
    <div class="md:hidden relative">
      <MobileNav client:load />
    </div>
  </div>
</header>
