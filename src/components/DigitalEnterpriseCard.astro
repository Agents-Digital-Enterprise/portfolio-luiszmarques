---
interface Props {
  title: string;
  description: string;
  stack: string[];
  agents_used: string[];
  slug: string;
  featured?: boolean;
  live?: string;
}
const { title, description, stack, agents_used, slug, featured, live } = Astro.props;
---
<a
  href={`/digital-enterprise/${slug}`}
  class="group block bg-bg-surface border border-border rounded-xl p-6 hover:border-accent/40 transition-all duration-200 hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-accent-light focus-visible:outline-offset-2"
>
  <div class="flex items-start justify-between gap-4 mb-3">
    <h3 class="font-semibold text-text-primary group-hover:text-accent-light transition-colors leading-snug">
      {title}
    </h3>
    {featured && (
      <span class="text-xs bg-accent-subtle text-accent-light border border-accent/20 px-2 py-0.5 rounded-full flex-shrink-0">
        First project
      </span>
    )}
  </div>

  <p class="text-text-secondary text-sm leading-relaxed mb-5 line-clamp-3">{description}</p>

  <div class="space-y-3">
    <div class="flex flex-wrap gap-1.5">
      {stack.map(tech => (
        <span class="text-xs text-text-muted bg-bg border border-border px-2 py-0.5 rounded-full">
          {tech}
        </span>
      ))}
    </div>
    <div class="flex flex-wrap gap-1.5 pt-1">
      {agents_used.slice(0, 4).map(agent => (
        <span class="text-xs text-text-muted">🤖 {agent}</span>
      ))}
      {agents_used.length > 4 && (
        <span class="text-xs text-text-muted">+{agents_used.length - 4} more</span>
      )}
    </div>
  </div>
</a>
