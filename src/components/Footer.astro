---
const year = new Date().getFullYear();
---
<footer class="border-t border-border mt-24 py-8 px-4">
  <div class="max-w-5xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-text-muted text-sm">
    <p>© {year} Luis Marques</p>
    <p class="text-center">
      Built by
      <a href="https://github.com/Agents-Digital-Enterprise/agency-agents-enterprise"
         target="_blank" rel="noopener noreferrer"
         class="text-accent-light hover:text-accent transition-colors focus-visible:outline-2 focus-visible:outline-accent-light focus-visible:outline-offset-2 rounded">
        Digital Enterprise OS
      </a>
      — AI agent fleet
    </p>
    <div class="flex gap-4">
      <a href="https://github.com/LuisZMarques" target="_blank" rel="noopener noreferrer"
         class="hover:text-text-primary transition-colors focus-visible:outline-2 focus-visible:outline-accent-light focus-visible:outline-offset-2 rounded" aria-label="GitHub">
        GitHub
      </a>
      <a href="/contact" class="hover:text-text-primary transition-colors focus-visible:outline-2 focus-visible:outline-accent-light focus-visible:outline-offset-2 rounded">Contact</a>
    </div>
  </div>
</footer>
